{
  "name": "planetearth.live",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Live planetary impact visualization — sourced directly from NOAA, NASA, USGS, Copernicus, NSIDC, GBIF, Global Forest Watch, National Grid ESO.",
  "license": "MIT",
  "homepage": "https://planetearth.live",
  "repository": {
    "type": "git",
    "url": "https://github.com/planetearth-live/planetearth-live"
  },
  "bugs": {
    "url": "https://github.com/planetearth-live/planetearth-live/issues",
    "email": "hello@planetearth.live"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit": "npm audit --omit=dev",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/three": "^0.171.0",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
